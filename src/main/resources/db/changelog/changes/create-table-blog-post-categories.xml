<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="0" author="emman">
        <createTable tableName="blog_post_categories">
            <column name="post_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="category_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey
                tableName="blog_post_categories"
                columnNames="post_id, category_id"
                constraintName="pk_blog_post_categories"/>

        <addForeignKeyConstraint
                baseTableName="blog_post_categories"
                baseColumnNames="post_id"
                constraintName="fk_blog_post_cat_post"
                referencedTableName="blog_posts"
                referencedColumnNames="id"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                baseTableName="blog_post_categories"
                baseColumnNames="category_id"
                constraintName="fk_blog_post_cat_category"
                referencedTableName="blog_categories"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
    </changeSet>
</databaseChangeLog>