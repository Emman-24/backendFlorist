<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.31.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1768833483586-1" author="emman">
        <createTable tableName="seo_redirects">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_seo_redirects"/>
            </column>
            <column name="old_path" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="new_path" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="entity_type" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="entity_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="status_code" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="hit_count" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="last_hit_at" type="DATETIME"/>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1768833483586-2" author="emman">
        <addUniqueConstraint columnNames="old_path" constraintName="uc_seo_redirects_oldpath"
                             tableName="seo_redirects"/>
    </changeSet>
    <changeSet id="1768833483586-3" author="emman">
        <createIndex indexName="idx_entity" tableName="seo_redirects">
            <column name="entity_type"/>
            <column name="entity_id"/>
        </createIndex>
    </changeSet>
    <changeSet id="1768833483586-4" author="emman">
        <createIndex indexName="idx_new_path" tableName="seo_redirects">
            <column name="new_path"/>
        </createIndex>
    </changeSet>
    <changeSet id="1768833483586-5" author="emman">
        <createIndex indexName="idx_old_path" tableName="seo_redirects" unique="true">
            <column name="old_path"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>